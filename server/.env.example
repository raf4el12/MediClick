# Database
DATABASE_URL="postgresql://mediclick:your_password@localhost:5436/mediclick?schema=public"

POSTGRES_USER="mediclick"
POSTGRES_PASSWORD="your_password"
POSTGRES_DB="mediclick"
POSTGRES_PORT="5436"

# JWT — generate strong secrets: openssl rand -base64 64
JWT_SECRET="CHANGE_ME_TO_A_STRONG_RANDOM_SECRET"
JWT_REFRESH_SECRET="CHANGE_ME_TO_A_DIFFERENT_STRONG_SECRET"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# App
NODE_ENV="development"
PORT=5100
CLIENT_URL="http://localhost:3000"

# Mail (SMTP)
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER=""
MAIL_PASS=""
MAIL_FROM="MediClick <noreply@mediclick.com>"

# RENIEC API — consulta de DNI peruano (https://decolecta.com)
# Regístrate gratis en https://decolecta.com/profile para obtener tu token (1000 consultas/mes gratis)
RENIEC_API_TOKEN=""

# Mercado Pago — Checkout Pro
# 1) Crear cuenta en https://www.mercadopago.com.pe/developers
# 2) Copiar Access Token y Public Key (modo test o producción) del dashboard y pegar aquí
MP_ACCESS_TOKEN=""
MP_PUBLIC_KEY=""
# Opcional — valida la firma HMAC del webhook (configurable en el dashboard de MP)
MP_WEBHOOK_SECRET=""
# URLs de retorno post-pago (apuntan al frontend)
MP_SUCCESS_URL="http://localhost:3000/payment/success"
MP_FAILURE_URL="http://localhost:3000/payment/failure"
MP_PENDING_URL="http://localhost:3000/payment/pending"
# URL pública del webhook. En desarrollo usar ngrok: `ngrok http 5100`
MP_NOTIFICATION_URL="https://CHANGE_ME.ngrok.io/payments/webhook"
# Minutos para completar el pago antes de que la cita expire
APPOINTMENT_PAYMENT_TIMEOUT_MINUTES=15
