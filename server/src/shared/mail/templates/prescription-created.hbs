{{#> base subject="Nueva receta medica"}}
<h2>Hola, {{patientName}}</h2>
<p>El Dr(a). <strong>{{doctorName}}</strong> te ha generado una receta medica. A continuacion el detalle:</p>

<table style="width: 100%; border-collapse: collapse; margin: 20px 0; font-size: 14px;">
  <thead>
    <tr style="background-color: #f1f5f9;">
      <th style="padding: 10px 12px; text-align: left; border-bottom: 2px solid #e2e8f0; color: #475569;">Medicamento</th>
      <th style="padding: 10px 12px; text-align: left; border-bottom: 2px solid #e2e8f0; color: #475569;">Dosis</th>
      <th style="padding: 10px 12px; text-align: left; border-bottom: 2px solid #e2e8f0; color: #475569;">Frecuencia</th>
      <th style="padding: 10px 12px; text-align: left; border-bottom: 2px solid #e2e8f0; color: #475569;">Duracion</th>
    </tr>
  </thead>
  <tbody>
    {{#each medications}}
    <tr>
      <td style="padding: 10px 12px; border-bottom: 1px solid #e2e8f0; color: #1e293b; font-weight: 500;">{{this.medication}}</td>
      <td style="padding: 10px 12px; border-bottom: 1px solid #e2e8f0; color: #475569;">{{this.dosage}}</td>
      <td style="padding: 10px 12px; border-bottom: 1px solid #e2e8f0; color: #475569;">{{this.frequency}}</td>
      <td style="padding: 10px 12px; border-bottom: 1px solid #e2e8f0; color: #475569;">{{#if this.duration}}{{this.duration}}{{else}}—{{/if}}</td>
    </tr>
    {{#if this.notes}}
    <tr>
      <td colspan="4" style="padding: 6px 12px 10px; border-bottom: 1px solid #e2e8f0; font-size: 13px; color: #64748b;">
        <em>Nota: {{this.notes}}</em>
      </td>
    </tr>
    {{/if}}
    {{/each}}
  </tbody>
</table>

{{#if instructions}}
<div class="info-card">
  <div class="row">
    <span class="label">Indicaciones:</span>
    <span class="value">{{instructions}}</span>
  </div>
</div>
{{/if}}

<p style="font-size: 13px; color: #64748b;">
  Puedes descargar tu receta en formato PDF desde la plataforma MediClick. Si tienes dudas sobre tu medicacion, consulta con tu medico.
</p>
{{/base}}
