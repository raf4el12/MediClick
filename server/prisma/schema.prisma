generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum AvailabilityType {
  REGULAR
  EXCEPTION
  EXTRA
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  TRANSFER
  INSURANCE
  OTHER
}

enum NotificationType {
  APPOINTMENT_REMINDER
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  NEW_APPOINTMENT
  PRESCRIPTION_CREATED
  PASSWORD_RESET
  GENERAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

enum MedicalHistoryStatus {
  ACTIVE
  RESOLVED
  CHRONIC
}

enum ScheduleBlockType {
  FULL_DAY
  TIME_RANGE
}

model Users {
  id            Int             @id @default(autoincrement())
  name          String
  email         String          @unique
  password      String
  photo         String?
  roleId        Int?
  isActive      Boolean         @default(true)
  validateEmail Boolean         @default(false)
  clinicId      Int?
  deleted       Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime?
  role          Roles?          @relation(fields: [roleId], references: [id], onDelete: SetNull)
  clinic        Clinics?        @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  profiles      Profiles[]
  notifications Notifications[]

  @@index([roleId, deleted])
  @@index([clinicId])
}

model Profiles {
  id             Int       @id @default(autoincrement())
  name           String
  lastName       String
  birthday       DateTime?
  gender         String?
  national       String?
  photo          String?
  phone          String?
  address        String?
  state          String?
  country        String?
  typeProfileId  Int? // Legacy — sin tabla asociada
  typeDocument   String?
  numberDocument String?
  userId         Int?
  deleted        Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime?
  user           Users?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient        Patients?
  doctor         Doctors?

  @@index([userId])
}

model Patients {
  id                 Int              @id @default(autoincrement())
  profileId          Int              @unique
  emergencyContact   String
  bloodType          String
  allergies          String?
  chronicConditions  String?              @map("chronic_conditions")
  isActive           Boolean          @default(true)
  deleted            Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime?
  profile            Profiles         @relation(fields: [profileId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  appointments       Appointments[]
  reviews            Reviews[]
  medicalHistory     MedicalHistory[]

  @@index([profileId])
}

model Doctors {
  id            Int                  @id @default(autoincrement())
  profileId     Int                  @unique
  licenseNumber String               @unique
  resume        String?
  isActive      Boolean              @default(true)
  maxOverbookPerDay Int              @default(2) // Máximo de sobrecupos por día
  clinicId      Int?
  deleted       Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime?
  profile       Profiles             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  clinic        Clinics?             @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  specialties   DoctorsSpecialties[]
  availability  Availability[]
  schedules     Schedules[]
  reviews        Reviews[]
  scheduleBlocks ScheduleBlocks[]

  @@index([profileId])
  @@index([isActive, deleted])
  @@index([clinicId])
}

model Specialties {
  id           Int                  @id @default(autoincrement())
  categoryId   Int
  name         String
  description  String?
  duration      Int                  @default(30)
  bufferMinutes Int?                 @default(0) // Minutos de descanso entre citas consecutivas
  price         Decimal?             @db.Decimal(10, 2)
  requirements String?
  icon         String?
  isActive     Boolean              @default(true)
  deleted      Boolean              @default(false)
  clinicId     Int?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime?
  category     Categories           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  clinic       Clinics?             @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  doctorLinks  DoctorsSpecialties[]
  availability Availability[]
  schedules    Schedules[]

  @@index([categoryId, isActive])
  @@index([clinicId])
}

model Categories {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  icon        String?
  color       String?
  order       Int?
  isActive    Boolean       @default(true)
  deleted     Boolean       @default(false)
  clinicId    Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime?
  clinic      Clinics?      @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  specialties Specialties[]

  @@index([isActive, deleted])
  @@index([order])
  @@index([clinicId])
}

model DoctorsSpecialties {
  id          Int         @id @default(autoincrement())
  doctorId    Int
  specialtyId Int
  deleted     Boolean     @default(false)
  createdAt   DateTime    @default(now())
  doctor      Doctors     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialty   Specialties @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([doctorId, specialtyId])
  @@index([doctorId])
  @@index([specialtyId])
}

model Availability {
  id          Int              @id @default(autoincrement())
  doctorId    Int
  specialtyId Int
  startDate   DateTime?
  endDate     DateTime?
  dayOfWeek   DayOfWeek
  timeFrom    DateTime
  timeTo      DateTime
  isAvailable Boolean          @default(true)
  type        AvailabilityType
  reason      String?
  clinicId    Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime?
  doctor      Doctors          @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialty   Specialties      @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  clinic      Clinics?         @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([doctorId, startDate, endDate])
  @@index([specialtyId])
  @@index([clinicId])
}

model Schedules {
  id           Int            @id @default(autoincrement())
  doctorId     Int
  specialtyId  Int
  scheduleDate DateTime
  timeFrom     DateTime
  timeTo       DateTime
  clinicId     Int?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime?
  doctor       Doctors        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialty    Specialties    @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  clinic       Clinics?       @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  appointments Appointments[]

  @@index([doctorId, scheduleDate])
  @@index([specialtyId])
  @@index([clinicId])
}

model Appointments {
  id            Int               @id @default(autoincrement())
  patientId     Int
  scheduleId    Int
  startTime     DateTime // Hora inicio exacta del slot de la cita
  endTime       DateTime // Hora fin exacta del slot de la cita
  reason        String?
  notes         String?
  status        AppointmentStatus @default(PENDING)
  paymentStatus PaymentStatus     @default(PENDING)
  amount        Decimal?          @db.Decimal(10, 2)
  cancelReason    String?
  cancellationFee Decimal?          @db.Decimal(10, 2)
  isOverbook      Boolean           @default(false) // Cita de sobrecupo
  reminderSent    Boolean           @default(false)
  pendingUntil    DateTime? // Deadline de pago; si status=PENDING y ahora > pendingUntil, la cita expira
  clinicId        Int?
  deleted         Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime?

  patient  Patients  @relation(fields: [patientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  schedule Schedules @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  clinic   Clinics?  @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  // Relaciones Core
  clinicalNotes ClinicalNotes[]
  prescription  Prescriptions?
  transactions  Transactions[]

  @@index([patientId, status])
  @@index([scheduleId, startTime, endTime])
  @@index([createdAt])
  @@index([status, paymentStatus])
  @@index([status, pendingUntil])
  @@index([clinicId])
}

model ClinicalNotes {
  id            Int          @id @default(autoincrement())
  appointmentId Int
  summary       String?      @db.Text
  plan          String?      @db.Text
  diagnosis     String?
  clinicId      Int?
  deleted       Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime?
  appointment   Appointments @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clinic        Clinics?     @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@index([clinicId])
}

model Prescriptions {
  id            Int       @id @default(autoincrement())
  appointmentId Int       @unique
  instructions  String?   @db.Text
  validUntil    DateTime?
  clinicId      Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime?

  appointment Appointments        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clinic      Clinics?            @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  items       PrescriptionItems[]

  @@index([appointmentId])
  @@index([clinicId])
}

model PrescriptionItems {
  id             Int           @id @default(autoincrement())
  prescriptionId Int
  medication     String // Nombre del medicamento
  dosage         String // Dosis (500mg)
  frequency      String // Frecuencia (Cada 8 horas)
  duration       String // Duración (Por 5 días)
  notes          String? // Notas extra por medicina
  prescription   Prescriptions @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
}

// MODELO NUEVO: Transacciones Financieras (Output para el negocio)
model Transactions {
  id            Int            @id @default(autoincrement())
  appointmentId Int
  amount        Decimal        @db.Decimal(10, 2)
  currency      String         @default("PEN")
  paymentMethod PaymentMethod? // null al crear la preference; se setea cuando el webhook confirma
  status        PaymentStatus
  gatewayId     String? // ID del pago en el gateway (Mercado Pago payment.id)
  preferenceId  String? // MP preference ID (el "intent" creado al iniciar el checkout)
  externalRef   String? // external_reference enviado a MP (= appointmentId)
  payerEmail    String?
  failureReason String?
  paidAt        DateTime?
  metadata      Json? // Respuesta cruda del gateway
  clinicId      Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime?

  appointment Appointments @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clinic      Clinics?     @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@index([gatewayId])
  @@index([preferenceId])
  @@index([externalRef])
  @@index([clinicId])
}

// MODELO NUEVO: Reseñas (Reputación)
model Reviews {
  id        Int      @id @default(autoincrement())
  doctorId  Int
  patientId Int
  rating    Int      @default(0) // 1 a 5
  comment   String?  @db.Text
  isVisible Boolean  @default(true) // Para moderación
  clinicId  Int?
  createdAt DateTime @default(now())

  doctor  Doctors  @relation(fields: [doctorId], references: [id])
  patient Patients @relation(fields: [patientId], references: [id])
  clinic  Clinics? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([doctorId])
  @@index([patientId])
  @@index([clinicId])
}

model Notifications {
  id        Int                 @id @default(autoincrement())
  userId    Int
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  message   String              @db.Text
  isRead    Boolean             @default(false)
  metadata  Json?
  sentAt    DateTime?
  clinicId  Int?
  deleted   Boolean             @default(false)
  createdAt DateTime            @default(now())

  user   Users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinics? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([type])
  @@index([clinicId])
}

model MedicalHistory {
  id            Int                  @id @default(autoincrement())
  patientId     Int
  condition     String
  description   String?              @db.Text
  diagnosedDate DateTime?
  status        MedicalHistoryStatus @default(ACTIVE)
  notes         String?              @db.Text
  clinicId      Int?
  deleted       Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime?

  patient Patients @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic  Clinics? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([patientId, status])
  @@index([patientId, createdAt])
  @@index([clinicId])
}

model ScheduleBlocks {
  id        Int               @id @default(autoincrement())
  doctorId  Int
  type      ScheduleBlockType
  startDate DateTime
  endDate   DateTime
  timeFrom  DateTime? // Solo para TIME_RANGE
  timeTo    DateTime? // Solo para TIME_RANGE
  reason    String
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime?

  doctor Doctors @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, startDate, endDate])
  @@index([isActive])
}

model Holidays {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime
  year        Int
  isRecurring Boolean  @default(false) // Feriados fijos que se repiten cada año
  isActive    Boolean  @default(true)
  clinicId    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime?

  clinic Clinics? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@unique([date, name, clinicId])
  @@index([year])
  @@index([date])
  @@index([clinicId])
}

model Clinics {
  id        Int       @id @default(autoincrement())
  name      String
  address   String?
  phone     String?
  email     String?   @unique
  timezone  String    @default("America/Lima")
  currency  String    @default("PEN")
  isActive  Boolean   @default(true)
  deleted   Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime?

  users          Users[]
  doctors        Doctors[]
  holidays       Holidays[]
  categories     Categories[]
  specialties    Specialties[]
  schedules      Schedules[]
  availability   Availability[]
  appointments   Appointments[]
  clinicalNotes  ClinicalNotes[]
  prescriptions  Prescriptions[]
  medicalHistory MedicalHistory[]
  transactions   Transactions[]
  notifications  Notifications[]
  reviews        Reviews[]

  roles        Roles[]

  @@index([isActive, deleted])
}

// --- PBAC (Permission-Based Access Control) ---

model Roles {
  id          Int               @id @default(autoincrement())
  name        String
  description String?
  isSystem    Boolean           @default(false)
  clinicId    Int?
  deleted     Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime?
  clinic      Clinics?          @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  users       Users[]
  permissions RolePermissions[]

  @@unique([name, clinicId])
  @@index([clinicId])
  @@index([isSystem])
}

model Permissions {
  id          Int               @id @default(autoincrement())
  action      String
  subject     String
  description String?
  roles       RolePermissions[]

  @@unique([action, subject])
  @@index([subject])
}

model RolePermissions {
  roleId       Int
  permissionId Int
  createdAt    DateTime    @default(now())
  role         Roles       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permissions @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}
